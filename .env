# ============================================================
# PaiSmart 一键 Docker 部署配置模板
# 用法：复制为 .env（cp .env.deploy.example .env），按注释修改
# ============================================================

# ---------- 服务器 ----------
# 服务器对外 IP（用于 MinIO 预签名地址 & 前端跨域白名单）
# deploy.sh 如果不填会尝试自动探测
SERVER_IP=8.163.106.81

# 前端访问端口（浏览器打开 http://服务器IP:WEB_PORT）
WEB_PORT=80

# 后端直连端口（主要用于调试，前端通过 nginx 代理不依赖这个）
BACKEND_PORT=8081

# MinIO 对外端口
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

# ---------- 数据库/中间件密码（生产环境建议改成强密码）----------
MYSQL_DATABASE=PaiSmart
MYSQL_ROOT_PASSWORD=PaiSmart2025

REDIS_PASSWORD=PaiSmart2025

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=PaiSmart2025

ELASTICSEARCH_PASSWORD=PaiSmart2025

# ---------- JWT 密钥（必须是 Base64） ----------
# 生成方法：openssl rand -base64 32
# deploy.sh 会在首次部署时自动生成
JWT_SECRET_KEY=VMzUadf9IQVoRl5PaDS7CeRYen3PppGb9Ktmo9UbCqU=

# ---------- 小红书 Cookie 池加密密钥（AES-GCM） ----------
# 用于加密后端 MySQL 里的 xhs_cookie 列，≥32 字节随机字符串
# deploy.sh 首次部署会自动生成；切换密钥会导致已入库的 cookie 无法解密
XHS_COOKIE_SECRET=

# ---------- 首次引导管理员 ----------
# 首次启动保持 true，脚本会自动创建管理员账号
# 成功登录后建议改成 false 再执行 `./deploy.sh restart`
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=Yyanyyan@666

# ---------- 注册策略 ----------
# OPEN        : 任何人填用户名密码即可注册
# INVITE_ONLY : 需要管理员生成邀请码
# CLOSED      : 完全关闭注册（只能管理员在后台创建）
APP_AUTH_REGISTRATION_MODE=OPEN
APP_AUTH_INVITE_REQUIRED=false

# ---------- 跨域白名单 ----------
# deploy.sh 会根据 SERVER_IP 自动填充这一项，这里可以留空
SECURITY_ALLOWED_ORIGINS=

# ---------- AI 密钥（必填，没有 AI 能力应用无法正常用）----------
# 主 LLM provider（OpenAI Chat Completions 兼容）：DeepSeek / SiliconFlow / Qwen DashScope / 智谱 GLM / Moonshot / 本地 vLLM 都通过 LLM_API_* 配置
# 例如:
#   官方 DeepSeek:        https://api.deepseek.com/v1 / deepseek-chat
#   SiliconFlow GLM:      https://api.siliconflow.cn/v1 / Pro/zai-org/GLM-5.1
#   阿里 Qwen 兼容模式:    https://dashscope.aliyuncs.com/compatible-mode/v1 / qwen-flash
#   智谱 GLM 直连:        https://open.bigmodel.cn/api/paas/v4 / glm-4.5-air
LLM_API_URL=https://api.siliconflow.cn/v1
LLM_API_MODEL=Pro/zai-org/GLM-5.1
LLM_API_KEY=sk-kxqetlajfuyowjzjcsoogejosfutwppqysnjgchgjoznvkss
# 兼容旧项目：保留 DEEPSEEK_API_* 同步生效（新部署不需要再写）
DEEPSEEK_API_URL=${LLM_API_URL}
DEEPSEEK_API_MODEL=${LLM_API_MODEL}
DEEPSEEK_API_KEY=${LLM_API_KEY}
AGENT_INLINE_IMAGE_DATA_URL_FOR_MODEL=true

# 阿里百炼 DashScope（向量模型 text-embedding-v4）：https://dashscope.console.aliyun.com/
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_API_KEY=sk-kxqetlajfuyowjzjcsoogejosfutwppqysnjgchgjoznvkss

# ---------- 资源配置（按服务器大小调整）----------
# 小服务器（4G 内存）：ES_HEAP_SIZE=512m，JAVA_XMX=512m
# 中服务器（8G 内存，推荐）：ES_HEAP_SIZE=1g，JAVA_XMX=1g
# 大服务器（16G+）：ES_HEAP_SIZE=2g，JAVA_XMX=2g
ES_HEAP_SIZE=1g
JAVA_XMS=512m
JAVA_XMX=1g

LOG_LEVEL_APP=INFO

KNOWLEDGE_BOOTSTRAP_ENABLED=false

EMBEDDING_DIMENSION=1024

USAGE_QUOTA_USE_USER_TOKEN_BALANCE=false
USAGE_QUOTA_LLM_ENABLED=false
USAGE_QUOTA_EMBEDDING_ENABLED=false

MINIO_PUBLIC_URL=http://8.163.106.81/minio-proxy
XHS_COOKIE_SECRET=eN4F1nDb7oOWkTkngeh0l9v42OA+cymLIjfSv4aPrGHuxDq0BuaNF5Kxd6c81YnW

# ---------- 聚光 MarketingAPI OAuth2 凭证（启动时自动落库）----------
# 打开后重启即可在 /data-sources 的"聚光广告"面板看到这条记录。
# 后续轮换 token：改下面三个变量 → 在 /data-sources 删掉旧行 → 重启。
XHS_SPOTLIGHT_SEED_ENABLED=true
XHS_SPOTLIGHT_SEED_LABEL=ZFC东方美妆种草集-HK1
# 用户于 2026-04-22 重新核对：advertiser_id 仅 974949，之前是把 advertiser_id+access_token 串在了一起
XHS_SPOTLIGHT_ADVERTISER_ID=974949
XHS_SPOTLIGHT_ACCESS_TOKEN=3b45948a1088a4a50ed0700e404041e6
XHS_SPOTLIGHT_REFRESH_TOKEN=7846485da785e1f3ee13ceb7be39681d
# 不填 expires-at 的话 seeder 会按 now + 7200s 写，ping 会显示剩余秒数
XHS_SPOTLIGHT_EXPIRES_AT=

# ---------- 聚光 MarketingAPI 开放平台应用凭证（用于 spotlight_oauth_refresh 工具）----------
# 这不是 advertiser_id！是在 https://ad.xiaohongshu.com 开放平台创建应用后拿到的 app_id / secret。
# 没配 → agent 工具 spotlight_oauth_refresh 会直接返回 config_missing 提示运维补配。
# 配上后 agent 才能在 access_token 快过期时自动 refresh 续签。
XHS_SPOTLIGHT_APP_ID=8800
XHS_SPOTLIGHT_APP_SECRET=ZGPlG9sVy6YhLXbT

# ---------- TikHub 第三方小红书 API（视频下载 + 笔记详情，零 cookie 风险）----------
# 启用后 xhs_third_party_note_detail / xhs_third_party_media_download / xhs_video_analyze
# 都会优先走 TikHub。鉴权头由后端自动加 "Authorization: Bearer ${api_key}"，
# 这里只填 token 本体，不要写 Bearer 前缀。
XHS_THIRD_PARTY_ENABLED=true
XHS_THIRD_PARTY_PROVIDER=tikhub
XHS_TIKHUB_ENABLED=true
XHS_TIKHUB_BASE_URL=https://api.tikhub.io
XHS_TIKHUB_API_KEY=lbMbAt4x0H2PtmupPZmR0Bb3NWahSZNevSfplBmsB+aFlA+8CHyqLgKgDQ==
XHS_TIKHUB_DEFAULT_QUALITY=best
# 200MB 上限；超大视频会拒绝下载并提示运营截断
XHS_TIKHUB_MAX_VIDEO_BYTES=209715200

# ---------- ASR 路由 ----------
# whisper-compatible：本地 paismart-whisper 容器（默认，零费用零联网零封号）
# dashscope-paraformer-v2：阿里百炼云端，要求 MinIO 公网可达
SMARTPAI_ASR_ENABLED=true
SMARTPAI_ASR_PROVIDER=whisper-compatible

# ---- 选 1：本地 Whisper（默认，装在 backend 镜像里，不另起容器）----
# 模型：tiny / base / small / medium（首次转写会从 HuggingFace 拉权重，可设 HF_ENDPOINT 镜像）
WHISPER_MODEL=base
SMARTPAI_WHISPER_MODE=local-faster-whisper
SMARTPAI_WHISPER_SCRIPT=/app/scripts/local_whisper_transcribe.py
# HTTP 外连自建服务时才需要 base-url，例如 http://192.168.1.10:9000
SMARTPAI_WHISPER_BASE_URL=
SMARTPAI_WHISPER_TASK=transcribe
SMARTPAI_WHISPER_LANGUAGE=zh
SMARTPAI_WHISPER_OUTPUT=json
SMARTPAI_WHISPER_TIMEOUT=600
SMARTPAI_WHISPER_MAX_AUDIO_BYTES=209715200

# ---- 选 2：DashScope paraformer-v2（云端，付费） ----
# 留空则 Java 层 fallback 到 EMBEDDING_API_KEY；建议申请独立 DashScope key 便于额度统计
SMARTPAI_ASR_BASE_URL=https://dashscope.aliyuncs.com
SMARTPAI_ASR_MODEL=paraformer-v2
DASHSCOPE_ASR_API_KEY=
